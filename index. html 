<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>HGZY ULTRA AI - LUXURY EDITION</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap');

        *{margin:0;padding:0;box-sizing:border-box;user-select:none}
        body{background:#000;overflow:hidden;height:100vh;width:100%; font-family: 'Orbitron', sans-serif;}
        iframe{width:100%;height:100%;border:none;z-index: 1;}

        /* LUXURY BACKGROUND ANIMATION */
        .petals-container {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
            z-index: 9998;
        }
        .petal {
            position: absolute;
            background: linear-gradient(45deg, #00ff00, #004400);
            border-radius: 150% 10% 150% 10%;
            opacity: 0.6;
            filter: drop-shadow(0 0 8px rgba(0, 255, 0, 0.8));
            animation: petalFall linear infinite;
        }
        @keyframes petalFall {
            0% { transform: translateY(-10vh) rotate(0deg); opacity: 0; }
            20% { opacity: 1; }
            100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
        }

        /* PREMIUM PANEL DESIGN - COMPACT SIZE */
        .sig-box {
            position: fixed;
            top: 50px; left: 10px; 
            width: 180px; 
            background: rgba(0, 20, 0, 0.85);
            backdrop-filter: blur(25px);
            border-radius: 20px;
            padding: 15px 10px;
            z-index: 9999;
            text-align: center;
            border: 2px solid #00ff00;
            box-shadow: 0 0 20px rgba(0, 255, 0, 0.4);
            touch-action: none;
        }

        #clock {
            font-size: 14px; color: #fff;
            margin-bottom: 10px; font-weight: 900;
            display: none;
            text-shadow: 0 0 10px #00ff00;
        }

        /* RESULT TEXT ANIMATION */
        #signalResult {
            display: flex;
            justify-content: center;
            gap: 4px;
            font-weight: 900;
            margin: 10px 0;
            height: 40px;
        }

        .letter {
            display: inline-block;
            opacity: 0;
            transform: translateY(-20px);
            animation: dropLetter 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
            font-size: 32px;
        }

        @keyframes dropLetter {
            to { opacity: 1; transform: translateY(0); }
        }

        .SMALL .letter { color: #ffff00; text-shadow: 0 0 20px #ffff00; } 
        .BIG .letter { color: #ff0055; text-shadow: 0 0 20px #ff0055; }   

        #timer { font-size: 11px; color: #00ffee; margin-bottom: 8px; font-weight: bold; text-transform: uppercase;}
        
        /* PERIOD NUMBER - MINIMALIST STYLE */
        #periodNumber { 
            font-size: 13px; 
            color: #ffffff; 
            margin-top: 10px; 
            padding: 0;
            background: none;
            border: none;
            letter-spacing: 0.5px;
            opacity: 0.9;
        }

        .loader-ai {
            width: 30px; height: 30px;
            border: 3px solid rgba(0, 255, 0, 0.1);
            border-top: 3px solid #00ff00; 
            border-radius: 50%;
            animation: spin 0.8s linear infinite; 
            margin: 10px auto;
        }
        @keyframes spin { 100% { transform: rotate(360deg); } }

        #passUI input {
            width:100%; padding:10px; margin-bottom:10px;
            background:rgba(0, 255, 0, 0.1); border: 1.5px solid #00ff00;
            color:#fff; border-radius:8px; text-align:center; font-size: 12px; outline: none;
        }
        .btn {
            background: linear-gradient(90deg, #00ff00, #00cc00);
            color:#000; border:none; padding:10px; 
            width:100%; font-weight:900; border-radius:8px; cursor:pointer; font-size: 11px;
        }
    </style>
</head>
<body>

<div class="petals-container" id="petals"></div>
<iframe src="https://hgnice.bet/#/register?invitationCode=511711502736"></iframe>

<div id="sigBox" class="sig-box">
    <div id="clock">00:00:00</div>
    <div id="passUI">
        <input type="password" id="passInput" placeholder="ENTER ACCESS KEY">
        <button class="btn" onclick="login()">ACTIVATE AI</button>
    </div>
    <div id="mainUI" style="display:none">
        <div id="timer">INITIALIZING...</div>
        <div id="loader" class="loader-ai" style="display:none"></div>
        <div id="resultContainer" style="display:none">
            <div id="signalResult"></div>
            <div id="periodNumber">PERIOD: ----</div>
        </div>
    </div>
</div>

<script>
    // LUXURY PARTICLE EFFECT
    function createPetal() {
        const container = document.getElementById('petals');
        const petal = document.createElement('div');
        petal.classList.add('petal');
        const size = Math.random() * 10 + 5 + 'px'; 
        petal.style.width = size;
        petal.style.height = size;
        petal.style.left = Math.random() * 100 + 'vw';
        petal.style.animationDuration = Math.random() * 3 + 4 + 's'; 
        container.appendChild(petal);
        setTimeout(() => petal.remove(), 6000);
    }
    setInterval(createPetal, 300);

    // CLOCK UPDATE
    function updateClock() {
        const now = new Date();
        const clockEl = document.getElementById('clock');
        if(clockEl) clockEl.innerText = now.getHours().toString().padStart(2,'0') + ":" + 
                                       now.getMinutes().toString().padStart(2,'0') + ":" + 
                                       now.getSeconds().toString().padStart(2,'0');
    }
    setInterval(updateClock, 1000);

    // LOGIN FUNCTION
    function login() {
        if(document.getElementById('passInput').value === "123456") {
            document.getElementById('passUI').style.display = 'none';
            document.getElementById('mainUI').style.display = 'block';
            document.getElementById('clock').style.display = 'block'; 
            startPredictor();
        } else { 
            alert("ACCESS DENIED! INVALID KEY."); 
        }
    }

    // ANIMATED RESULT DISPLAY
    function displayResult(text) {
        const resEl = document.getElementById('signalResult');
        resEl.innerHTML = '';
        resEl.className = text;
        text.split('').forEach((char, index) => {
            const span = document.createElement('span');
            span.innerText = char;
            span.classList.add('letter');
            span.style.animationDelay = (index * 0.1) + 's';
            resEl.appendChild(span);
        });
    }

    let currentPeriod = null;

    // AI PREDICTOR LOGIC
    function startPredictor() {
        setInterval(() => {
            const now = new Date();
            const sec = now.getUTCSeconds();
            const remain = 30 - (sec % 30);
            const totalSec = (now.getUTCHours() * 3600) + (now.getUTCMinutes() * 60) + sec;
            const pId = Math.floor(totalSec / 30) + 1;
            const shortId = String(pId).slice(-4);

            document.getElementById('timer').innerText = "ANALYSIS: " + remain + "s";

            if (remain <= 3) {
                // Showing Loader during last 3 seconds
                document.getElementById('resultContainer').style.display = 'none';
                document.getElementById('loader').style.display = 'block';
                currentPeriod = null;
            } else {
                if (currentPeriod !== shortId) {
                    // Prediction Logic Calculation
                    const logic = (pId * 13 + 7) % 10;
                    const res = (logic >= 5) ? "BIG" : "SMALL";
                    
                    document.getElementById('loader').style.display = 'none';
                    displayResult(res);
                    document.getElementById('periodNumber').innerText = "PERIOD: " + shortId;
                    document.getElementById('resultContainer').style.display = 'block';
                    
                    currentPeriod = shortId;
                }
            }
        }, 1000);
    }

    // DRAGGABLE PANEL LOGIC (MOBILE TOUCH)
    const box = document.getElementById('sigBox');
    let offX, offY, isDown = false;
    box.addEventListener('touchstart', (e) => {
        isDown = true;
        offX = e.touches[0].clientX - box.offsetLeft;
        offY = e.touches[0].clientY - box.offsetTop;
    });
    document.addEventListener('touchmove', (e) => {
        if(!isDown) return;
        box.style.left = (e.touches[0].clientX - offX) + 'px';
        box.style.top = (e.touches[0].clientY - offY) + 'px';
    });
    document.addEventListener('touchend', () => isDown = false);
</script>

</body>
</html>